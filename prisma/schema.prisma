// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Pokemon {
  id     Int      @id @default(autoincrement())
  name   String   @unique
  types  String[]
  sprite String

  @@index([name])
  @@index([types])
}
